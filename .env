# ── CARA ALTERNATIF JIKA LOGIN GAGAL TERUS ──────────────────
# Isi ZURA_COOKIE dengan cookie session dari browser (lebih andal).
# Cara ambil:
#   1. Login ke https://x.zurastore.my.id di Chrome/Firefox
#   2. Tekan F12 → tab Application → Cookies → x.zurastore.my.id
#   3. Salin nama & value semua cookie yang ada, pisahkan titik koma
# Contoh:
#   ZURA_COOKIE=PHPSESSID=abc123def456; laravel_session=xyz789
# Catatan: kalau ZURA_COOKIE diisi, bot pakai ini dan SKIP login otomatis
ZURA_COOKIE=

# URL base website (jangan diubah)
